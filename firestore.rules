rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly allow reads to the test connection path
    match /test/connection {
      allow read: if true;
    }

    // Require authentication for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
